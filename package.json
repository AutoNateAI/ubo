{
  "name": "ubo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "simulator:start": "scripts/start-velxio.sh",
    "simulator:stop": "docker stop ubo-velxio",
    "simulator:logs": "docker logs -f ubo-velxio",
    "simulator:build": "docker build -f vendor/velxio/Dockerfile.standalone -t ubo-velxio:local vendor/velxio"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "firebase": "^12.7.0",
    "lucide-react": "^0.562.0",
    "vite": "^7.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.9.3"
  }
}
